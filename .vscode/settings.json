{
  // ── Workspace accent: teal/geo theme ──────────────────────────────
  "vscode_custom_css.imports": ["file:///Users/kimberlyhamilton/Library/Application%20Support/Code/User/custom.css"],

  // Icon theme (built-in, no install): folders get a distinct colored
  // folder icon; files get per-extension icons (py, yaml, md, etc.)
  "workbench.iconTheme": "material-icon-theme",

  // Material Icon Theme options
  "material-icon-theme.folders.color": "#41d1d1",
  "material-icon-theme.folders.theme": "specific",
  "material-icon-theme.opacity": 1,

  "workbench.colorCustomizations": {
    "statusBar.noFolderBackground": "#2d2d2d",
    "activityBar.activeBorder": "#41d1d1",
    "sideBar.background": "#0a2e2e",
    "sideBar.foreground": "#cce8e8",
    "sideBarTitle.foreground": "#41d1d1",
    "sideBarSectionHeader.background": "#0f4444",
    "sideBarSectionHeader.foreground": "#41d1d1",
    "sideBarSectionHeader.border": "#1a6b6b",
    "list.activeSelectionBackground": "#1a6b6b",
    "list.activeSelectionForeground": "#ffffff",
    "list.inactiveSelectionBackground": "#0f3d3d",
    "list.inactiveSelectionForeground": "#e7f5f5",
    "list.hoverBackground": "#0f3333",
    "list.hoverForeground": "#ffffff",
    "list.focusBackground": "#1a6b6b",
    "list.focusForeground": "#ffffff",
    "list.highlightForeground": "#41d1d1",
    "tree.indentGuidesStroke": "#1a6b6b"
  }
}
